# ─────────────────────────────────────────────
#  Telegram News Bot — Environment Template
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your channel username (with @) or numeric ID
# e.g.  @mychannel   or   -1001234567890
TELEGRAM_CHANNEL_ID=@your_channel_here

# Free API key from https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# Comma-separated keywords to track
KEYWORDS=Bitcoin,MSFT,Apple,Tesla,AI,OpenAI

# How often to fetch news (minutes)
INTERVAL_MINUTES=30

# Optional: category-based news (uncomment to enable)
# NEWS_CATEGORY=technology
# NEWS_COUNTRY=us

# Optional: max articles per fetch cycle (default 5)
# MAX_ARTICLES_PER_CYCLE=5
